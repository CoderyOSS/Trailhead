{
  "model": "deepseek/deepseek-v4-flash",
  "agent": {
    "opsx-deepseek": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-flash",
      "description": "OpenSpec reviewer — DeepSeek",
      "hidden": true
    }
  },
  "provider": {
    "LLM_PROVIDER": {
      "api": "deepseek",
      "options": {
        "apiKey": "LLM_API_KEY",
        "baseURL": "LLM_BASE_URL"
      }
    }
  },
  "permission": {
    "read": { "*": "allow" },
    "glob": { "*": "allow" },
    "grep": { "*": "allow" },
    "list": { "*": "allow" },
    "bash": { "*": "ask" },
    "edit": { "*": "ask" },
    "write": { "*": "ask" },
    "webfetch": "deny",
    "websearch": "deny",
    "question": "deny",
    "doom_loop": "deny",
    "git": "GIT_COMMIT_PERMISSION"
  },
  "mcp": {
    "trailhead": {
      "type": "remote",
      "url": "TRAILHEAD_URL/mcp/sse"
    }
  },
  "instructions": ["AGENTS.md"]
}
